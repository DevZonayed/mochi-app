# dependencies
node_modules/
.pnpm-store/

# This is a pnpm workspace — pnpm-lock.yaml is the only lockfile. A stray
# package-lock.json / yarn.lock makes EAS Build (and CI) pick npm/yarn and run
# `npm ci` against an empty lockfile, so `expo` + plugins never install and the
# build dies in "Read app config". Never commit/upload these.
package-lock.json
yarn.lock

# builds / generated
dist/
dist-electron/
build/
web-build/
release/
.turbo/
*.tsbuildinfo

# …but DO keep the desktop app's committed build resources (app icon +
# generator) that electron-builder consumes when packaging.
!apps/desktop/build/
!apps/desktop/build/**

# expo / metro
.expo/
.expo-shared/

# databases (runtime)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# operator-local skills installed via add_skill_to_project — but the team
# settings.json (PreToolUse merge-block hook) MUST ship: it's how PR #63's
# human-confirm merge gate enforces itself against agent-side `gh pr merge` /
# `git push origin master`. Ignore everything under .claude/ EXCEPT the
# settings file. Do NOT delete the negation.
.claude/*
!.claude/settings.json

# env / secrets
.env
.env.*
!.env.example

# tooling / local state
.context/
.continuum/
.playwright-cli/
.DS_Store
*.log
coverage/
