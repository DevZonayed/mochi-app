# dependencies
node_modules/
.pnpm-store/

# This is a pnpm workspace — pnpm-lock.yaml is the only lockfile. A stray
# package-lock.json / yarn.lock makes EAS Build (and CI) pick npm/yarn and run
# `npm ci` against an empty lockfile, so `expo` + plugins never install and the
# build dies in "Read app config". Never commit/upload these.
package-lock.json
yarn.lock

# builds / generated
dist/
dist-electron/
build/
web-build/
release/
.turbo/
*.tsbuildinfo

# …but DO keep the desktop app's committed build resources (app icon +
# generator) that electron-builder consumes when packaging.
!apps/desktop/build/
!apps/desktop/build/**

# expo / metro
.expo/
.expo-shared/

# databases (runtime)
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite
*.sqlite-wal
*.sqlite-shm

# .claude — PRECISE ignore-list. We TRACK skills/, settings.json, CLAUDE.md
# (project memory survives a fresh clone on a new Mac); we IGNORE Mac-local
# transcripts, caches, and operator-private overrides.
.claude/settings.local.json
.claude/projects/
.claude/.cache/
.claude/shell-snapshots/
.claude/todos/
.claude/statsig/
.claude/worktrees/
.claude/*.local.json

# .continuum — TRACK STATE.md + chain/ (project memory); IGNORE the operator's
# pasted-image stash (Mac-local, can be large + private).
.continuum/Attachment/

# env / secrets
.env
.env.*
!.env.example

# tooling / local state
.context/
.playwright-cli/
.DS_Store
*.log
coverage/
