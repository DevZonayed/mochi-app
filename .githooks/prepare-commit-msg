#!/usr/bin/env bash
# prepare-commit-msg — strip AI-attribution trailers from commit messages.
#
# Why: clients of this repo (DevZonayed/mochi-app) see commits on GitHub. Lines
# like `Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>` or
# `🤖 Generated with [Claude Code](https://claude.com/claude-code)` break the
# illusion that a human shipped the change. The maestro-commit skill tells the
# agent never to write them; THIS hook is the last-line safety net that catches
# anything that slips through (CLI commits, IDE auto-trailers, partner tools).
#
# What it strips (case-insensitive on the trailer key):
#   Co-Authored-By: Claude …
#   Co-Authored-By: <anything>@noreply.anthropic.com … (anthropic noreply form)
#   🤖 Generated with [Claude Code](...)  /  🤖 Generated with Claude Code
#   Generated by Claude Code
#
# What it LEAVES alone:
#   - Real human co-authors (e.g. `Co-Authored-By: Jane Doe <jane@example.com>`)
#   - Conventional Commits subject/body/footers
#   - Any other trailer/footer
#
# Hook is invoked by git with three args: $1=message-file, $2=source, $3=sha.
# It's idempotent (running twice is a no-op) and prints nothing on success.

set -eu

MSG_FILE="${1:-}"
[ -n "$MSG_FILE" ] && [ -f "$MSG_FILE" ] || exit 0

# Skip merge/squash/fixup commit messages — they already carry structure we
# shouldn't second-guess. (The agent makes regular commits + amends.)
SOURCE="${2:-}"
case "$SOURCE" in
  merge|squash|commit) exit 0 ;;
esac

TMP="$(mktemp "${TMPDIR:-/tmp}/mst-commit-msg.XXXXXX")"
trap 'rm -f "$TMP"' EXIT

# Pattern set (POSIX ERE). Anchored at line start so we never eat substrings of
# unrelated text. The trailer key match is case-insensitive (BRE flag won't
# help here, so we spell out the variants — that's what the agents emit).
#
# 1. Claude Code's standard Co-Authored-By trailer (Claude as author).
# 2. The noreply@anthropic.com email regardless of display name.
# 3. The 🤖 generated-with footer (bracketed or unbracketed Claude Code).
# 4. The plain "Generated by Claude Code" footer.
awk '
  # Pattern 1: Co-Authored-By: Claude …
  /^[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-[Bb][Yy]:[[:space:]]*Claude([[:space:]]|$)/ { next }
  # Pattern 2: Co-Authored-By: anyone <…@noreply.anthropic.com> / anthropic noreply
  /^[Cc][Oo]-[Aa][Uu][Tt][Hh][Oo][Rr][Ee][Dd]-[Bb][Yy]:[[:space:]].*noreply@anthropic\.com/ { next }
  # Pattern 3: 🤖 Generated with [Claude Code](url) or just 🤖 Generated with Claude Code
  /^🤖[[:space:]]*Generated with \[?Claude Code\]?/ { next }
  # Pattern 4: Generated by Claude Code
  /^Generated by Claude Code[[:space:]]*$/ { next }
  { print }
' "$MSG_FILE" > "$TMP"

# Collapse 3+ trailing blank lines that the removal may have left behind, and
# trim trailing whitespace on the file. (No-op when nothing was stripped → idempotent.)
awk '
  { lines[NR] = $0 }
  END {
    end = NR
    while (end > 0 && lines[end] ~ /^[[:space:]]*$/) end--
    for (i = 1; i <= end; i++) print lines[i]
  }
' "$TMP" > "$TMP.2"
mv "$TMP.2" "$TMP"

# Only rewrite when content actually changed → keeps git's mtime stable for tools
# that watch the file (and makes the hook a true no-op on clean messages).
if ! cmp -s "$MSG_FILE" "$TMP"; then
  cat "$TMP" > "$MSG_FILE"
fi
