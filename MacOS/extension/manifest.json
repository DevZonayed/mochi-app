{
  "manifest_version": 3,
  "name": "Mochi",
  "version": "0.1.0",
  "description": "A squishy little browser companion for AI assistants. Each AI session gets its own Chrome tab group; your other tabs stay untouched.",
  "permissions": [
    "tabs",
    "tabGroups",
    "scripting",
    "storage",
    "alarms",
    "activeTab",
    "debugger",
    "downloads",
    "cookies"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16":  "icons/mochi-16.png",
    "32":  "icons/mochi-32.png",
    "48":  "icons/mochi-48.png",
    "128": "icons/mochi-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mochi",
    "default_icon": {
      "16":  "icons/mochi-16.png",
      "32":  "icons/mochi-32.png",
      "48":  "icons/mochi-48.png",
      "128": "icons/mochi-128.png"
    }
  },
  "commands": {
    "open-send-hint-modal": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac":     "Command+Shift+M"
      },
      "description": "Open the Mochi send-hint modal on the current page"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["mochi-modal.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
