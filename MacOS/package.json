{
  "name": "@maestro/macos",
  "version": "0.1.28",
  "private": true,
  "description": "Maestro WebKit macOS app — the Node brain + React renderer served by the native WKWebView shell (MacOS/webview-app) via the headless sidecar (MacOS/sidecar).",
  "author": "Maestro",
  "scripts": {
    "dev": "vite --config vite.web.config.ts",
    "build": "tsc --noEmit -p tsconfig.json && vite build --config vite.web.config.ts",
    "preview": "vite preview --config vite.web.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:renderer": "vitest run --config vitest.renderer.config.mjs",
    "test:dom": "vitest run --config vitest.dom.config.mjs",
    "test:all": "vitest run && vitest run --config vitest.renderer.config.mjs && vitest run --config vitest.dom.config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@openai/codex": "^0.140.0",
    "@whiskeysockets/baileys": "6.7.23",
    "highlight.js": "^11.11.1",
    "playwright-core": "^1.61.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@maestro/design-tokens": "workspace:*",
    "@maestro/realtime": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~18.3.12",
    "@types/react-dom": "~18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  }
}
