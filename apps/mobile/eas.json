{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "NPM_CONFIG_IGNORE_SCRIPTS": "true" }
    }
  },
  "submit": {
    "production": {}
  }
}
