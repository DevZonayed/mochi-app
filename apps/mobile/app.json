{
  "expo": {
    "name": "Maestro",
    "slug": "maestro-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "maestro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.maestro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Maestro uses the camera to scan the pairing QR code shown on your Mac."
      }
    },
    "android": {
      "package": "ai.maestro.app",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Maestro uses the camera to scan the pairing QR code shown on your Mac."
        }
      ],
      "expo-audio",
      "@config-plugins/react-native-webrtc"
    ]
  }
}
