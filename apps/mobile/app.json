{
  "expo": {
    "name": "Maestro",
    "slug": "maestro-mobile",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "maestro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.maestro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Maestro uses the camera to scan the pairing QR code shown on your Mac."
      }
    },
    "android": {
      "package": "ai.maestro.app",
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Maestro uses the camera to scan the pairing QR code shown on your Mac."
        }
      ],
      "expo-audio",
      "@config-plugins/react-native-webrtc",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "28b856bc-5534-4a50-b6af-70cd5803ee68"
      }
    },
    "owner": "devzonayed"
  }
}
