{
  "name": "@maestro/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "registry:sources:dry-run": "node scripts/sync-skill-sources.mjs --dry-run",
    "registry:sources:sync": "node scripts/sync-skill-sources.mjs --sync",
    "registry:verify": "node scripts/verify-registry-db.mjs",
    "registry:hydrate": "node scripts/verify-registry-db.mjs --hydrate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.2.0",
    "@xenova/transformers": "^2.17.2",
    "better-auth": "^1.6.20",
    "better-sqlite3": "^12.10.1",
    "fastify": "^5.2.1",
    "ioredis": "^5.11.1",
    "kysely": "^0.29.2",
    "pg": "^8.22.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "ioredis-mock": "^8.13.1",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
