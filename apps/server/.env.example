# Account multi-tenant server (apps/server). Set these in Dokploy app env.
PORT=8080

# PostgreSQL — accounts, sessions, devices (Better Auth + device registry).
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/maestro

# Redis — presence, snapshot mirror, cross-instance pub/sub.
REDIS_URL=redis://HOST:6379

# Better Auth — generate: openssl rand -base64 32  (>= 32 chars)
BETTER_AUTH_SECRET=change-me-to-a-32+-char-random-secret
BETTER_AUTH_URL=https://api.nexalance.cloud

# WebRTC TURN (optional; all-null → clients use public STUN).
# TURN_HOST=turn:turn.nexalance.cloud:3478
# TURN_SECRET=your-coturn-static-auth-secret
