{
  "name": "@maestro/core",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/db/schema.sql','dist/db/schema.sql')\"",
