    "test": "vitest run",
    "cli": "tsx src/cli.ts"
  },
  "dependencies": {
    "@maestro/rpc-contract": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  }
}
